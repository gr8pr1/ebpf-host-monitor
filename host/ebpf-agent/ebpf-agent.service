[Unit]
Description=eBPF Adaptive Security Monitoring Agent
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ebpf-agent -config /etc/ebpf-agent/config.yaml
Restart=always
RestartSec=10
User=root

NoNewPrivileges=false
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log /var/lib/ebpf-agent

[Install]
WantedBy=multi-user.target
